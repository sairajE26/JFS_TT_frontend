{
  "version": 2,
  "builds": [
    {
      "src": "JFS-TT-main/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "JFS-TT-main/build"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/JFS-TT-main/build/index.html" }
  ]
}
